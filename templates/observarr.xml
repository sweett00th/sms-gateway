<?xml version="1.0"?>
<Container version="2">
  <Name>observarr</Name>
  <Repository>ghcr.io/sweett00th/observarr:latest</Repository>
  <Registry>https://ghcr.io/sweett00th/observarr</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/sweett00th/observarr/issues</Support>
  <Project>https://github.com/sweett00th/observarr</Project>
  <Overview>Internal LAN-only ObservaRR observability app for home server media automation webhooks from Jellyseerr/Seerr, Jellyfin, Radarr, Sonarr, and SABnzbd. The container runs a Deno/Hono API and serves the React admin panel. Textbelt SMS delivery is available only when explicitly enabled. Textbelt replies can be received through the configured WEBHOOK_BASE_URL. Email delivery is not configured yet.</Overview>
  <Category>Tools:</Category>
  <TemplateURL>https://raw.githubusercontent.com/sweett00th/observarr/main/templates/observarr.xml</TemplateURL>
  <WebUI>http://[IP]:[PORT:3020]/</WebUI>
  <Icon>https://raw.githubusercontent.com/sweett00th/observarr/main/assets/icon.png</Icon>
  <Icon/>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Appdata" Target="/data" Default="/mnt/user/appdata/observarr" Mode="rw" Description="Persistent SQLite database and avatar cache directory." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/observarr</Config>
  <Config Name="Web UI Port" Target="3020" Default="3020" Mode="tcp" Description="HTTP port for ObservaRR." Type="Port" Display="always" Required="true" Mask="false">3020</Config>
  <Config Name="TZ" Target="TZ" Default="America/New_York" Mode="" Description="Container timezone." Type="Variable" Display="always" Required="false" Mask="false">America/New_York</Config>
  <Config Name="DB_PATH" Target="DB_PATH" Default="/data/observarr.db" Mode="" Description="SQLite database file path inside the container." Type="Variable" Display="always" Required="true" Mask="false">/data/observarr.db</Config>
  <Config Name="ADMIN_USERNAME" Target="ADMIN_USERNAME" Default="admin" Mode="" Description="Initial admin username used only when no users exist." Type="Variable" Display="always" Required="false" Mask="false">admin</Config>
  <Config Name="ADMIN_PASSWORD" Target="ADMIN_PASSWORD" Default="" Mode="" Description="Initial admin password used only when no users exist. Set before first start, then remove or rotate after bootstrap if desired." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="SESSION_TTL_DAYS" Target="SESSION_TTL_DAYS" Default="7" Mode="" Description="Server-side session lifetime in days." Type="Variable" Display="always" Required="false" Mask="false">7</Config>
  <Config Name="COOKIE_SECURE" Target="COOKIE_SECURE" Default="false" Mode="" Description="Set true only when serving behind HTTPS. Keep false for LAN HTTP." Type="Variable" Display="always" Required="false" Mask="false">false</Config>
  <Config Name="EVENT_BUFFER_MINUTES" Target="EVENT_BUFFER_MINUTES" Default="10" Mode="" Description="In-memory Event Console retention window in minutes. Events are not persisted." Type="Variable" Display="always" Required="false" Mask="false">10</Config>
  <Config Name="EVENT_BUFFER_MAX" Target="EVENT_BUFFER_MAX" Default="250" Mode="" Description="Maximum in-memory Event Console events retained for this container runtime." Type="Variable" Display="always" Required="false" Mask="false">250</Config>
  <Config Name="EVENT_RAW_MAX_BYTES" Target="EVENT_RAW_MAX_BYTES" Default="20000" Mode="" Description="Maximum sanitized raw webhook payload bytes included in each in-memory Event Console event." Type="Variable" Display="always" Required="false" Mask="false">20000</Config>
  <Config Name="WEBHOOK_BASE_URL" Target="WEBHOOK_BASE_URL" Default="" Mode="" Description="Public or LAN URL Textbelt can reach for reply webhooks, for example http://192.168.1.44:3020. Used to build /webhook/textbelt/reply for opt-in replies." Type="Variable" Display="always" Required="false" Mask="false"/>`r`n  <Config Name="SHARED_SECRET" Target="SHARED_SECRET" Default="" Mode="" Description="Optional webhook shared secret. When set, webhook requests must include the x-sms-secret header." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="JELLYFIN_URL" Target="JELLYFIN_URL" Default="" Mode="" Description="Internal Jellyfin base URL used only by the server for profile import, for example http://192.168.1.50:8096." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="JELLYFIN_API_KEY" Target="JELLYFIN_API_KEY" Default="" Mode="" Description="Jellyfin API key used only by the server for profile import. Imported users are not automatically subscribed to notifications." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="NOTIFICATIONS_ENABLED" Target="NOTIFICATIONS_ENABLED" Default="false" Mode="" Description="Set true only after configuring Textbelt and an explicitly opted-in test recipient. Defaults false to prevent accidental SMS." Type="Variable" Display="always" Required="false" Mask="false">false</Config>
  <Config Name="TEXTBELT_KEY" Target="TEXTBELT_KEY" Default="" Mode="" Description="Secret Textbelt API key for SMS delivery. Required only when notifications are enabled." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="TEXTBELT_SENDER" Target="TEXTBELT_SENDER" Default="" Mode="" Description="Optional approved Textbelt sender name, such as ObservaRR or your configured sender." Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>

