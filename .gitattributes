# Normalize text files in the repo.
* text=auto

# Keep code/config files LF for GitHub Actions, Docker, Linux containers, Unraid.
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf

# Windows-specific scripts may use CRLF.
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf